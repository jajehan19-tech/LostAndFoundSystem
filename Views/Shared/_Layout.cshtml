<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lost & Found</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        .navbar-brand {
            font-weight: 700;
            font-size: 20px;
        }

        body {
            background-color: #f4f6fb;
        }

        .navbar {
            box-shadow: 0 2px 12px rgba(0,0,0,0.15);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark"
         style="background: linear-gradient(135deg, #0f3460, #533483);">
        <div class="container-fluid">
            <a class="navbar-brand text-white" asp-controller="Dashboard" asp-action="Index">
                🔍 Lost & Found
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Dashboard" asp-action="Index">
                                🏠 Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Item" asp-action="Index">
                                🔍 View Items
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Item" asp-action="Create">
                                📝 Report Item
                            </a>
                        </li>
                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Admin" asp-action="Index">
                                    ⚙️ Admin Panel
                                </a>
                            </li>
                        }
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <li class="nav-item me-2">
                            <a asp-controller="Account" asp-action="Profile"
                               class="nav-link text-white">
                                👤 @Context.Session.GetString("UserName")
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Logout"
                               class="btn btn-danger btn-sm px-3">
                                Logout
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>