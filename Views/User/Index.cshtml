@model IEnumerable<LostAndFoundSystem.Models.User>
@{
    ViewData["Title"] = "User List";
}

<div class="container mt-4">
    <h2>User List</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Create New User</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>User ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Address</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@user.Address</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@user.UserId" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@user.UserId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>