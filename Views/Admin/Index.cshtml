@model IEnumerable<LostAndFoundSystem.Models.User>
@{
    ViewData["Title"] = "Admin Panel";
}

<div class="container mt-4">
    <h2>⚙️ Admin Panel</h2>
    <p class="text-muted">Manage all users, roles and system data</p>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center border-0 bg-light p-3">
                <h3 class="text-primary">@ViewBag.TotalUsers</h3>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-0 bg-light p-3">
                <h3 class="text-success">@ViewBag.TotalRoles</h3>
                <p class="mb-0">Total Roles</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center border-0 bg-light p-3">
                <h3 class="text-warning">@ViewBag.TotalItems</h3>
                <p class="mb-0">Total Items</p>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <a asp-controller="Role" asp-action="Index" class="btn btn-outline-primary w-100 py-3">
                👑 Manage Roles
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="User" asp-action="Index" class="btn btn-outline-success w-100 py-3">
                👥 Manage Users
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Item" asp-action="Index" class="btn btn-outline-warning w-100 py-3">
                📦 Manage Items
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary w-100 py-3">
                🏠 Back to Dashboard
            </a>
        </div>
    </div>

    <h4 class="mt-3">All Users</h4>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Last Login</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>
                        <span class="badge bg-primary">@user.Role?.RoleName</span>
                    </td>
                    <td>@user.LastLogIn.ToString("dd MMM yyyy")</td>
                    <td>
                        <a asp-controller="User" asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-controller="User" asp-action="Delete" asp-route-id="@user.UserId" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>