@model IEnumerable<LostAndFoundSystem.Models.Role>
@{
    ViewData["Title"] = "Role List";
}

<div class="container mt-4">
    <h2>Role List</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Create New Role</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Role ID</th>
                <th>Role Name</th>
                <th>Role Description</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model)
            {
                <tr>
                    <td>@role.Id</td>
                    <td>@role.RoleName</td>
                    <td>@role.RoleDescription</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@role.Id" class="btn btn-info btn-sm">Details</a>
                        <a asp-action="Edit" asp-route-id="@role.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@role.Id" class="btn btn-danger btn-sm">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>